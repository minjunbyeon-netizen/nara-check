# ─── 나라장터 API 설정 ───────────────────────────────────────
# 공공데이터포털(data.go.kr) 가입 후 "나라장터 입찰공고정보서비스" 신청
# https://www.data.go.kr/data/15129394/openapi.do
NARAJANGTEO_API_KEY=여기에_공공데이터포털_서비스키_입력

# ─── Claude (Anthropic) API 설정 ────────────────────────────
# https://console.anthropic.com/
ANTHROPIC_API_KEY=여기에_Claude_API키_입력

# ─── 이메일 설정 (Gmail 기준) ────────────────────────────────
# Gmail 앱 비밀번호 사용 (2단계 인증 후 앱 비밀번호 발급)
EMAIL_SENDER=보내는_이메일@gmail.com
EMAIL_PASSWORD=Gmail_앱_비밀번호_16자리
EMAIL_RECIPIENT=받는_이메일@gmail.com
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
